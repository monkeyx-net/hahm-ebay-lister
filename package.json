{
  "name": "ebay-lister-web",
  "version": "1.0.0",
  "private": true,
  "description": "Friendly web app that turns item photos into ready-to-post eBay listings using Claude.",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "dev": "concurrently -k -n server,client \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist-server/index.mjs",
    "start": "NODE_ENV=production node dist-server/index.mjs",
    "typecheck": "tsc --noEmit",
    "refresh:categories": "tsx --env-file-if-exists=.env.local scripts/refresh-category-map.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@hono/node-server": "^1.13.0",
    "fast-xml-parser": "^5.9.3",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
