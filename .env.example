# Copy this file to ".env.local" for local development, and set the same
# variables in your deployment environment (Coolify → Environment, or Docker env)
# for production.

# Your Anthropic API key — get one at https://console.anthropic.com/
# This stays on the SERVER and is never exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: a second AI provider via OpenRouter (https://openrouter.ai/keys) —
# one key, many models, including free vision-capable ones. Leave blank to use
# Anthropic only. When set, free OpenRouter models appear alongside Claude
# models in the app's Model Settings picker (only vision-capable models are
# offered, since sorting/writing both send photos).
OPENROUTER_API_KEY=

# Optional: raise the price ceiling (USD per million tokens, checked against
# both prompt and completion price) for OpenRouter models offered in the
# picker. Defaults to 0 — free models only. Only matters if OPENROUTER_API_KEY
# is set.
OPENROUTER_MAX_PRICE_PER_M_TOKENS=0

# Optional: a third AI provider via OmniRoute (https://github.com/diegosouzapw/OmniRoute)
# — a self-hosted gateway that aggregates 250+ providers (many free) behind one
# OpenAI-compatible API. Unlike Anthropic/OpenRouter, this typically runs on
# your own infrastructure (a sidecar container, or wherever you point it), not
# a cloud API. Leave OMNIROUTE_ALLOWED_MODELS blank to leave OmniRoute disabled.
#
# Base URL of your OmniRoute instance's API. Defaults to http://localhost:20128/v1
# (OmniRoute's default) if unset — only change this if OmniRoute runs elsewhere
# (a different host/port, or a sidecar container reachable at a different name).
OMNIROUTE_BASE_URL=
# Only needed if your OmniRoute instance has REQUIRE_API_KEY enabled (it's off
# by default upstream). Get a key from its Dashboard → Endpoints panel.
OMNIROUTE_API_KEY=
# REQUIRED to enable OmniRoute: a comma-separated list of OmniRoute model ids
# you've personally verified support image input. OmniRoute aggregates 250+
# providers and its /v1/models response doesn't reliably say which models
# support vision, so — unlike OpenRouter — this app can't auto-detect it; you
# opt models in explicitly. Example: gpt-4o,gemini-2.0-flash
OMNIROUTE_ALLOWED_MODELS=

# REQUIRED for deployed apps: an access code protecting the AI endpoints, so
# strangers can't burn your Anthropic credits. A production deployment FAILS
# CLOSED without this — every AI route returns an error until it's set. Pick any
# code you can type on your phone — the app asks for it once per device and
# remembers it. Leave blank only for local development.
APP_SECRET=

# ── Phase 2: eBay posting (not required for sorting/writing listings) ─────────
# From your eBay keyset at https://developer.ebay.com/. You can reuse your
# existing keyset's App ID + Cert ID, as long as you create a NEW, dedicated
# RuName for this web app (so the Python lister's RuName stays untouched).
# Leave these blank until you're ready for posting.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=
# Random secret used to encrypt your stored eBay connection. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Your deployed app URL, used for the OAuth redirect (e.g. https://your-app.example.com)
APP_URL=
# Optional: your ZIP code. Only used once, to create an eBay inventory location
# if your account doesn't already have one. Defaults to 10001 if unset.
EBAY_LOCATION_POSTAL_CODE=

# Optional: default package weight/size sent to eBay so CALCULATED-shipping
# policies can publish (eBay returns error 25020 if weight is missing). Weight is
# in ounces (16 = 1 lb); dimensions are in inches. You can still edit weight/size
# on each listing in eBay afterward. Defaults: 16 oz, 12 x 9 x 3 in.
EBAY_DEFAULT_PACKAGE_WEIGHT_OZ=16
EBAY_DEFAULT_PACKAGE_LENGTH_IN=12
EBAY_DEFAULT_PACKAGE_WIDTH_IN=9
EBAY_DEFAULT_PACKAGE_HEIGHT_IN=3
